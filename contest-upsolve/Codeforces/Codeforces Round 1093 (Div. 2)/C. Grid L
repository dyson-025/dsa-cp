x =  p + 2*q;
for (ll m = 1; 2*m*m + 2*m <= x; m++) {
    ll a = x - m;
    ll b = 2*m + 1;

    if (a % b) continue;

    ll n = a / b;
    if (n <= 0) continue;

    if (q <= n*(m+1) && q <= m*(n+1)) {
        cout << n << " " << m << endl;
        return;
    }
}
