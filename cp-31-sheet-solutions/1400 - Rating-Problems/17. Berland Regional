💻 Final Code (Optimal)
#include <bits/stdc++.h>
using namespace std;
#define ll long long

int main() {
    ios::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;

    while (t--) {
        int n;
        cin >> n;

        vector<int> u(n), s(n);
        for (int &x : u) cin >> x;
        for (int &x : s) cin >> x;

        unordered_map<int, vector<ll>> mpp;

        // grouping
        for (int i = 0; i < n; i++) {
            mpp[u[i]].push_back(s[i]);
        }

        vector<ll> ans(n + 1, 0);

        for (auto &it : mpp) {
            auto &v = it.second;

            // sort descending
            sort(v.rbegin(), v.rend());

            // prefix sum
            for (int i = 1; i < v.size(); i++) {
                v[i] += v[i - 1];
            }

            int sz = v.size();

            // contribute to k
            for (int k = 1; k <= sz; k++) {
                int usable = (sz / k) * k;
                if (usable > 0) {
                    ans[k] += v[usable - 1];
                }
            }
        }

        for (int k = 1; k <= n; k++) {
            cout << ans[k] << " ";
        }
        cout << "\n";
    }

    return 0;
}
