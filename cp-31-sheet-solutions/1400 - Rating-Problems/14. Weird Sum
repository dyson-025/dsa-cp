рҹ’» 7. Your Code (Explained Cleanly)
void solve() {
    ll n, m;
    cin >> n >> m;

    unordered_map<ll, vector<ll>> row_map;
    unordered_map<ll, vector<ll>> col_map;

    // Step 1: store positions
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < m; j++) {
            ll col; 
            cin >> col;

            row_map[col].push_back(i);
            col_map[col].push_back(j);
        }
    }

    ll ans = 0;

    // Step 2: process rows
    for(auto &r: row_map) {
        vector<ll> v = r.second;

        sort(v.begin(), v.end());

        ll sum = accumulate(v.begin(), v.end(), 0ll);

        for(int i = 0; i < v.size(); i++) {
            sum -= v[i]; // remove current

            ans += (sum - (v.size() - i - 1) * v[i]);
        }
    }

    // Step 3: process columns
    for(auto &c: col_map) {
        vector<ll> v = c.second;

        sort(v.begin(), v.end());

        ll sum = accumulate(v.begin(), v.end(), 0ll);

        for(int i = 0; i < v.size(); i++) {
            sum -= v[i];

            ans += (sum - (v.size() - i - 1) * v[i]);
        }
    }

    cout << ans << endl;
}
