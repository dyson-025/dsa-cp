💻 Clean Code (Optimized)
#include <bits/stdc++.h>
using namespace std;

#define ll long long
const ll MOD = 1e9 + 7;
const int MAXN = 200005;

ll fact[MAXN];

// precompute factorial
void precompute() {
    fact[0] = 1;
    for (int i = 1; i < MAXN; i++) {
        fact[i] = (fact[i-1] * i) % MOD;
    }
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(NULL);

    precompute();

    int t;
    cin >> t;

    while (t--) {
        int n;
        cin >> n;

        vector<int> a(n);
        for (int &x : a) cin >> x;

        // Step 1: compute global AND
        int X = a[0];
        for (int i = 1; i < n; i++) {
            X &= a[i];
        }

        // Step 2: count frequency of X
        int cnt = 0;
        for (int x : a) {
            if (x == X) cnt++;
        }

        // Step 3: check condition
        if (cnt < 2) {
            cout << 0 << '\n';
            continue;
        }

        // Step 4: compute answer
        ll ans = (1LL * cnt * (cnt - 1)) % MOD;
        ans = (ans * fact[n - 2]) % MOD;

        cout << ans << '\n';
    }

    return 0;
}
⏱️ Time Complexity
AND computation → O(n)
Counting → O(n)
Precompute factorial → O(n) once

