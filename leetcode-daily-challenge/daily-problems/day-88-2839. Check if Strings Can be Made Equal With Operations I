🧠 Intuition (Super Simple Version)
🔑 Operation:

You can swap indices where:

j - i = 2

👉 Possible swaps:

(0, 2)
(1, 3)
💡 Key Insight:

Again, indices split into 2 independent groups:

Group	Indices
Group 1	0, 2
Group 2	1, 3

👉 You can only swap within these groups

🎯 Final Condition

For strings to become equal:

Characters at indices (0,2) must match as a group
Characters at indices (1,3) must match as a group

👉 Order doesn't matter inside group, only frequency matters

🔥 Simplest Way to Think

Instead of frequency arrays, since size = 4:

👉 Just sort both groups and compare

🚀 Clean Optimized Code
class Solution {
public:
    bool checkStrings(string s1, string s2) {
        // Group 1: indices 0 and 2
        string a1 = {s1[0], s1[2]};
        string a2 = {s2[0], s2[2]};
        
        // Group 2: indices 1 and 3
        string b1 = {s1[1], s1[3]};
        string b2 = {s2[1], s2[3]};

        sort(a1.begin(), a1.end());
        sort(a2.begin(), a2.end());
        sort(b1.begin(), b1.end());
        sort(b2.begin(), b2.end());

        return (a1 == a2) && (b1 == b2);
    }
};
⚡ Even Shorter (BEST for contest)
class Solution {
public:
    bool checkStrings(string s1, string s2) {
        return 
            multiset<char>{s1[0], s1[2]} == multiset<char>{s2[0], s2[2]} &&
            multiset<char>{s1[1], s1[3]} == multiset<char>{s2[1], s2[3]};
    }
};
